# Leave empty in dev to use Vite proxy to http://127.0.0.1:8000 (see vite.config.ts).
# Set to full API origin in production builds, e.g. https://api.example.com
VITE_API_URL=

# Google OAuth 2.0 Web Client ID (GIS “Sign in with Google”)
VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
