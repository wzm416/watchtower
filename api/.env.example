# Postgres (required for persistence, migrations, and DB integration tests)
DATABASE_URL=postgresql://watchtower:watchtower@localhost:5432/watchtower

# Google OAuth 2.0 client ID(s) from Google Cloud Console (GIS / Sign in with Google)
# Comma-separated if you have several (e.g. web + dev)
GOOGLE_CLIENT_IDS=your-google-oauth-client-id.apps.googleusercontent.com

# Bearer token for POST /internal/jobs/tick (Cloud Scheduler or manual cron)
CRON_BEARER_TOKEN=generate-a-long-random-secret

# Optional: Resend (https://resend.com) for price alerts
# RESEND_API_KEY=re_...
# RESEND_FROM_EMAIL=Watchtower <onboarding@resend.dev>
# APP_PUBLIC_URL=https://your-web-host.example

# CORS: comma-separated origins for the Vite dev server / production web origin
# CORS_ORIGINS=http://localhost:5173
